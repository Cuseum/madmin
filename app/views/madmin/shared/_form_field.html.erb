<div class="form-group">
  <%= render "madmin/shared/label", form: form, field: field %>
  <%= render partial: field.to_partial_path("form"), locals: { field: field, record: record, form: form, resource: resource } %>
  <%= tag.div field.options.description, class: "form-description" if field.options.description.present? %>
  <%= tag.div field.hint, class: "form-hint" if field.hint.present? %>
</div>
