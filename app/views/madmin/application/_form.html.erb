<%= form_with model: [:madmin, record], url: (record.persisted? ? resource.show_path(record) : resource.index_path), local: true do |form| %>
  <% if form.object.errors.any? %>
    <div class="alert alert-danger">
      <div class="">There was <%= pluralize form.object.errors.full_messages.count, "error" %> with your submission:</div>

      <ul>
        <% form.object.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <% if resource.form_block %>
    <%= render_arbre resource.form_block %>
  <% elsif resource.form_items.any? %>
    <% resource.form_items.each do |item| %>
      <% if item.is_a?(Symbol) %>
        <% attribute = resource.attributes[item] %>
        <% next unless attribute&.field&.present? && attribute.field.visible?(action_name) %>
        <%= render "madmin/shared/form_field", field: attribute.field, record: record, form: form, resource: resource %>
      <% elsif item.is_a?(Madmin::Resource::FormRow) %>
        <%= render_form_row(item, form: form, record: record, resource: resource) %>
      <% else %>
        <%= render partial: "form_section", locals: { form_section: item, record: record, form: form, resource: resource } %>
      <% end %>
    <% end %>
  <% else %>
    <% resource.attributes.values.select{ _1.field.present? && _1.field.visible?(action_name) }.each do |attribute| %>
      <%= render "madmin/shared/form_field", field: attribute.field, record: record, form: form, resource: resource %>
    <% end %>
  <% end %>

  <%= form.submit class: "btn btn-primary" %>
  <%= link_to "Cancel", (record.persisted? ? resource.show_path(record) : resource.index_path), class: "btn" %>
<% end %>
