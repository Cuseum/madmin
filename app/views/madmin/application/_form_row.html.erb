<div class="form-row" style="--madmin-cols: <%= form_row.cols.size %>">
  <% form_row.cols.each do |col| %>
    <div class="form-col">
      <% col.attribute_names.each do |attr_name| %>
        <% attribute = resource.attributes[attr_name] %>
        <% next if attribute.nil? || attribute.field.nil? || !attribute.field.visible?(action_name) %>
        <%= render "madmin/shared/form_field", field: attribute.field, record: record, form: form, resource: resource %>
      <% end %>
    </div>
  <% end %>
</div>
