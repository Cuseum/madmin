<div class="form-section">
  <h3 class="form-section-title"><%= form_section.label %></h3>
  <% if form_section.description.present? %>
    <p class="form-section-description"><%= form_section.description.respond_to?(:call) ? form_section.description.call : form_section.description %></p>
  <% end %>
  <% form_section.attribute_names.each do |attr_name| %>
    <% attribute = resource.attributes[attr_name] %>
    <% next if attribute.nil? || attribute.field.nil? || !attribute.field.visible?(action_name) %>
    <%= render "madmin/shared/form_field", field: attribute.field, record: record, form: form, resource: resource %>
  <% end %>
</div>
